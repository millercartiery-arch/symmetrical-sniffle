{
  "name": "massmail-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-frontend.mjs",
    "dev:frontend:raw": "vite",
    "dev:backend": "node scripts/dev-backend.mjs",
    "dev:backend:raw": "npm --prefix ../backend run dev",
    "dev:full": "node scripts/dev-full.mjs",
    "build": "vite build",
    "build:tauri": "vite build --mode tauri",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --strictPort --port 8080 --host"
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@ant-design/icons": "^5.2.6",
    "@tauri-apps/api": "^1.5.0",
    "antd": "^5.14.1",
    "axios": "^1.13.5",
    "i18next": "^25.8.10",
    "i18next-browser-languagedetector": "^7.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.0.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.2.0",
    "vite-plugin-compression": "^0.5.1"
  }
}
