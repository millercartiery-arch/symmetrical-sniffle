# 生产环境前端环境变量示例（复制为 .env.production 或 .env.production.local 并按部署修改）

# 应用环境标识
VITE_APP_ENV=production
VITE_SANDBOX=false

# API 与 Socket 基地址（必填，与后端同源或配置 CORS）
# 同域部署示例：https://your-domain.com
VITE_API_BASE_URL=https://your-domain.com/api
VITE_API_URL=https://your-domain.com
VITE_SOCKET_BASE_URL=https://your-domain.com

# 可选：部署在子路径时设置，如 /app，则资源与路由以 /app 为前缀
# VITE_BASE_PATH=/app

# Tauri 桌面构建时由构建脚本设置，一般无需在此配置
# VITE_TAURI=1
