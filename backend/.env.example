# 复制为 .env 并填写实际值。
# 本地开发：根目录 npm run dev 会同时启后端(3000)与前端(8080)，前端代理 /api 到 127.0.0.1:3000，无需改 CORS。
# 数据库完整配置（建库、迁移、读写）在服务器完成；本地仅需可选的可读连接用于查看数据。

# ---------- 数据库（服务器上必填；本地可选） ----------
# 服务器：在服务器 /var/www/massmail/backend/.env 配置读写用户，并在此执行 db:full / db:ensure / 迁移。
# 本地：可预留只读用户连接服务器库或只读副本，仅作可读数据库视图（查数据、调试）；不在此做建库与迁移。
DB_HOST=localhost
DB_PORT=3306
DB_USER=massmail
DB_PASSWORD=你的数据库密码
DB_NAME=massmail

# 远程调试：设为 true 时 GET /api/health 会返回当前连接的 DB 目标（host/database）
# DEBUG_DB_TARGET=true

# Redis（队列与锁；不填或未启动时仅会打印一次连接失败，不影响会话/聊天接口）
REDIS_URL=redis://localhost:6379
# DEBUG_REDIS=true

# 本地调试会话/聊天页面免登录（仅开发）：设为 true 后 /api/user/chat/* 不需 JWT
# DEBUG_PUBLIC_CHAT=true

# 服务端口与鉴权（本地开发可不建 .env，默认 PORT=3000、NODE_ENV=development）
PORT=3000
NODE_ENV=production
JWT_SECRET=你的JWT密钥至少32位

# 生产环境 CORS：允许的前端来源，逗号分隔（与 ALLOWED_ORIGINS 二选一或同时设置）
# 域名挂载：前端与 API 同域名（同 Nginx 反代）时可不配，后端会按请求 Host 同域放行
# 例：CORS_ORIGINS=https://app.example.com 或 SERVER_PUBLIC_ORIGIN=https://hkd.llc
# CORS_ORIGINS=
# ALLOWED_ORIGINS=
# SERVER_PUBLIC_ORIGIN=   # 可选，与 CORS_ORIGINS 同效，单域名时用此项即可

# 生产环境同机托管前端：指定前端静态目录绝对路径，后端将优先从该目录提供静态资源
# 例：FRONTEND_DIR=/var/www/massmail/frontend/dist
# FRONTEND_DIR=

# 代理密码加密（可选，未配置则回退 MSG_ENC_KEY）
# PROXY_ENC_KEY=用 openssl rand -base64 32 生成
