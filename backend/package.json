{
  "name": "massmail-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "start:worker": "tsx src/worker-entry.ts",
    "test:import": "tsx src/tests/import-normalizer.test.ts",
    "test:send": "tsx src/tests/send-test.ts",
    "test:stateless": "tsx src/tests/stateless-sender.test.ts",
    "test:protocol-matrix": "tsx src/tests/protocol-send-matrix.test.ts",
    "test:gateway-smoke": "tsx src/tests/gateway-smoke.test.ts",
    "test:media-dispatch-smoke": "tsx src/tests/media-dispatch-smoke.test.ts",
    "test:gateway-orchestrator": "tsx src/tests/gateway-orchestrator-concurrency.test.ts",
    "test:scheduler-components": "tsx src/tests/scheduler-components-smoke.test.ts",
    "test:subaccount": "tsx src/tests/subaccount-distribution-smoke.test.ts",
    "test:subaccount-distribution-smoke": "tsx src/tests/subaccount-distribution-smoke.test.ts",
    "test:subaccount-distribution": "tsx src/tests/subaccount-distribution-smoke.test.ts",
    "test:regression-gateway": "npm run test:scheduler-components && npm run test:subaccount",
    "package": "pkg .",
    "migrate:tenant": "node scripts/add_tenant_support.cjs",
    "migrate:proxy-pass": "tsx scripts/migrate-proxy-pass.ts",
    "migrate:normalize-phone": "node scripts/migrate-normalize-phone.js",
    "db:ensure": "tsx scripts/run-schema-ensure.ts",
    "db:full": "tsx scripts/run-schema-full.ts",
    "db:migrate": "npm run db:ensure",
    "seed": "tsx scripts/seed-test-data.ts",
    "test:jwt-auth": "node scripts/test_jwt_auth.cjs",
    "send-flow-check": "node scripts/send-flow-check.mjs",
    "test:tn-send": "tsx scripts/run-tn-test-send.ts",
    "check:db-api": "tsx scripts/check_db_and_api.ts"
  },
  "bin": "dist/index.js",
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "node_modules/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "https-proxy-agent": "^7.0.6",
    "i18next": "^25.8.10",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "mysql2": "^3.9.8",
    "otplib": "^13.3.0",
    "puppeteer": "^24.38.0",
    "puppeteer-cluster": "^0.25.0",
    "qrcode": "^1.5.4",
    "react-i18next": "^16.5.4",
    "socket.io": "^4.8.3",
    "tsx": "^4.21.0",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "cross-env": "^7.0.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
